];

const tabBaseClass =
  "px-4 py-3 border-b-2 md:border-l-2 md:border-b-0 border-muted hover:bg-secondary/50 transition-all text-left whitespace-nowrap";
const activeTabClass = "text-primary border-primary bg-secondary/30";
const inactiveTabClass = "text-muted-foreground";
---

<section id="experience" class="pb-8 bg-secondary/20" data-experience-tabs>
  <div class="container">
    <h2 class="section-title">Where I've Worked</h2>

    <div class="flex flex-col md:flex-row gap-6">
      <nav
        aria-label="Work experience"
        class="md:w-1/4 flex md:flex-col overflow-x-auto md:overflow-visible"
      >
        {
          experienceData.map((job, index) => (
            <a
              href={`#experience-panel-${index}`}
              class:list={[
                tabBaseClass,
                index === 0 ? activeTabClass : inactiveTabClass,
              ]}
              aria-current={index === 0 ? "true" : undefined}
              aria-controls={`experience-panel-${index}`}
              data-experience-tab
            >
              {job.company}{" "}
              <span class="float-end text-muted-foreground font-mono text-sm">
                {job.period}
              </span>
            </a>
          ))
        }
      </nav>

      <div class="md:w-3/4 md:mr-32 space-y-8">
        {
          experienceData.map((job, index) => (
            <article
              id={`experience-panel-${index}`}
              class="animate-fade-in"
              data-experience-panel
            >
              <h3 class="text-xl font-bold pb-2">
                {job.title} <span class="text-primary">@ {job.company}</span>
              </h3>

              <ul class="space-y-2">
                {job.responsibilities.map((item) => (
                  <li class="flex">
                    <span class="text-primary mr-2 mt-1">▹</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  const activeTabClasses = [
    "text-primary",
    "border-primary",
    "bg-secondary/30",
  ];
  const inactiveTabClasses = ["text-muted-foreground"];

  for (const root of document.querySelectorAll("[data-experience-tabs]")) {
    const tabs = [
      ...root.querySelectorAll<HTMLElement>("[data-experience-tab]"),
    ];
    const panels = [
      ...root.querySelectorAll<HTMLElement>("[data-experience-panel]"),
    ];

    const setActiveTab = (activeIndex: number) => {
      for (const [index, tab] of tabs.entries()) {
        const isActive = index === activeIndex;
        const panel = panels[index];

        tab.classList.toggle(activeTabClasses[0], isActive);
        tab.classList.toggle(activeTabClasses[1], isActive);
        tab.classList.toggle(activeTabClasses[2], isActive);
        tab.classList.toggle(inactiveTabClasses[0], !isActive);

        if (isActive) {
          tab.setAttribute("aria-current", "true");
        } else {
          tab.removeAttribute("aria-current");
        }

        if (panel) {
          panel.hidden = !isActive;
        }
      }
    };

    for (const [index, tab] of tabs.entries()) {
      tab.addEventListener("click", (event) => {
        event.preventDefault();
        setActiveTab(index);
      });
    }

    setActiveTab(0);
  }
</script>
