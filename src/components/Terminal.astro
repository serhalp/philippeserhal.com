---
interface Props {
  command?: string;
  title?: string;
  prompt?: string;
  class?: string;
  showCursor?: boolean;
}

const {
  command = "",
  title = "bash",
  prompt = "guest@philippeserhal.com",
  class: className = "",
  showCursor = true,
} = Astro.props;
---

<div
  class={`bg-terminal p-6 rounded-lg font-mono text-md text-left mb-8 ${className}`}
>
  <div class="flex items-center mb-4">
    <div class="w-3 h-3 rounded-full bg-red-500 mr-2"></div>
    <div class="w-3 h-3 rounded-full bg-yellow-500 mr-2"></div>
    <div class="w-3 h-3 rounded-full bg-green-500 mr-2"></div>
    <span class="text-muted-foreground text-sm">{title}</span>
  </div>
  <p class="mb-2">
    <span class="text-green-400">{prompt}</span>:<span class="text-blue-400"
      >~</span
    >$ {command}
  </p>
  <div>
    <slot />
    {
      showCursor ? (
        <p class="flex items-center">
          <span class="text-foreground">_</span>
          <span class="animate-cursor-blink ml-1">|</span>
        </p>
      ) : null
    }
  </div>
</div>
